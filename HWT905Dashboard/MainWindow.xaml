<Window x:Class="HWT905Dashboard.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="clr-namespace:HWT905Dashboard.Controls"
        Title="HWT905 Factory-Trusted Dashboard REV13" Width="1920" Height="1080" MinWidth="1280" MinHeight="760"
        WindowStartupLocation="CenterScreen" WindowState="Maximized" WindowStyle="None"
        Background="{StaticResource BgBrush}" Foreground="{StaticResource TextBrush}"
        Loaded="Window_Loaded" Closing="Window_Closing">
    <Window.Resources>
        <Style x:Key="PanelTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#F4FAFF"/>
            <Setter Property="FontSize" Value="15"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Margin" Value="14,10,10,4"/>
        </Style>
        <Style x:Key="SmallLabel" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#9FB1C2"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="BigValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="#74FF36"/>
            <Setter Property="FontSize" Value="26"/>
            <Setter Property="FontWeight" Value="Bold"/>
        </Style>
        <Style x:Key="MetricBox" TargetType="Border" BasedOn="{StaticResource PanelBorder}">
            <Setter Property="Padding" Value="10,6"/>
            <Setter Property="Margin" Value="4"/>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="42"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="28"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#070B10" BorderBrush="#142230" BorderThickness="0,0,0,1" MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="150"/>
                </Grid.ColumnDefinitions>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0,0,0">
                    <TextBlock Text="▣" Foreground="#4EA3FF" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <TextBlock Text="HWT905 Factory-Trusted Dashboard" FontSize="18" FontWeight="Bold" Foreground="#F7FBFF" VerticalAlignment="Center"/>
                    <TextBlock Text="  •  read-only factory-trusted monitor" FontSize="12" Foreground="#7E93A8" VerticalAlignment="Center" Margin="12,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                    <Button x:Name="BtnMin" Width="38" Height="28" Content="—" Click="BtnMin_Click" BorderBrush="#1C2B3A" Background="#07111A"/>
                    <Button x:Name="BtnMax" Width="38" Height="28" Content="□" Click="BtnMax_Click" BorderBrush="#1C2B3A" Background="#07111A"/>
                    <Button x:Name="BtnClose" Width="38" Height="28" Content="×" Click="BtnClose_Click" BorderBrush="#4A1D1D" Background="#1A0C0C"/>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1" Margin="8">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="248"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,8,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Padding="8" Margin="0,0,0,5">
                    <StackPanel>
                        <TextBlock Text="CONNECTION" Style="{StaticResource SmallLabel}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                            <Ellipse x:Name="ConnectionDot" Width="12" Height="12" Fill="#FF4238" Margin="0,4,8,0"/>
                            <TextBlock x:Name="ConnectionText" Text="Disconnected" Foreground="#FF4238" FontWeight="Bold" FontSize="16"/>
                        </StackPanel>
                        <TextBlock x:Name="PortBaudText" Text="No port" Foreground="#CBD8E5" FontSize="13" Margin="0,8,0,8"/>
                        <Button x:Name="BtnConnect" Content="Connect" Height="38" Margin="0,6,0,0" Click="BtnConnect_Click"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Padding="8" Margin="0,0,0,8">
                    <StackPanel>
                        <Button x:Name="BtnNavOverview" Tag="Overview" Content="⌂   OVERVIEW" Height="44" Background="#0C4380" BorderBrush="#2D8CFF" HorizontalContentAlignment="Left" Click="NavButton_Click"/>
                        <Button x:Name="BtnNavAttitude" Tag="Attitude" Content="◉   ATTITUDE" Height="42" HorizontalContentAlignment="Left" BorderBrush="#173247" Click="NavButton_Click"/>
                        <Button x:Name="BtnNavSensors" Tag="Sensors" Content="◍   SENSORS" Height="42" HorizontalContentAlignment="Left" BorderBrush="#173247" Click="NavButton_Click"/>
                        <Button x:Name="BtnNavGraphs" Tag="Graphs" Content="⌁   GRAPHS" Height="42" HorizontalContentAlignment="Left" BorderBrush="#173247" Click="NavButton_Click"/>
                        <Button x:Name="BtnNavAbout" Tag="About" Content="ⓘ   ABOUT" Height="42" HorizontalContentAlignment="Left" BorderBrush="#173247" Click="NavButton_Click"/>
                    </StackPanel>
                </Border>

                <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="12" Margin="0,0,0,8">
                    <StackPanel>
                        <TextBlock Text="PORT" Style="{StaticResource SmallLabel}"/>
                        <Grid Margin="0,4,0,8">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="38"/></Grid.ColumnDefinitions>
                            <ComboBox x:Name="PortCombo" Height="34"/>
                            <Button Grid.Column="1" Content="↻" Click="BtnRefreshPorts_Click" Padding="0"/>
                        </Grid>

                        <TextBlock Text="BAUD RATE" Style="{StaticResource SmallLabel}" Margin="0,4,0,0"/>
                        <ComboBox x:Name="BaudCombo" Height="34" Margin="4,4,4,8"/>


                        <Button x:Name="BtnAutoDetect" Content="Auto Detect + Lock" Height="38" Click="BtnAutoDetect_Click"/>
                        <Button x:Name="BtnFactoryViewReset" Content="Factory View Reset" Height="38" Margin="0,8,0,0" BorderBrush="#55D92B" Foreground="#74FF36" Click="BtnFactoryViewReset_Click"/>
                        <TextBlock Text="Local only: clears dashboard offsets. It never writes to the HWT905." Foreground="#7E93A8" FontSize="11" TextWrapping="Wrap" Margin="2,6,2,0"/>
                        <StackPanel Orientation="Horizontal" Margin="6,6,0,0">
                            <TextBlock Text="▣" Foreground="#74FF36" FontSize="18" Margin="0,-2,6,0"/>
                            <TextBlock x:Name="LockText" Text="Port unlocked" Foreground="#9FB1C2" FontWeight="Bold"/>
                        </StackPanel>
                    </StackPanel>
                </Border>
            </Grid>

            <Grid x:Name="MainContentGrid" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition x:Name="MetricsRow" Height="78"/>
                    <RowDefinition x:Name="VisualRow" Height="3.05*"/>
                    <RowDefinition x:Name="TilesRow" Height="74"/>
                    <RowDefinition x:Name="GraphsRow" Height="1.25*"/>
                    <RowDefinition x:Name="DataRow" Height="166"/>
                </Grid.RowDefinitions>

                <UniformGrid x:Name="TopMetricsPanel" Grid.Row="0" Columns="7" Margin="0,0,0,8">
                    <Border Style="{StaticResource MetricBox}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="UPTIME" Style="{StaticResource SmallLabel}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="UptimeText" Text="00:00:00" Foreground="#3190FF" FontSize="21" FontWeight="Bold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricBox}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="DATA RATE" Style="{StaticResource SmallLabel}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="DataRateText" Text="0 Hz" Foreground="#3190FF" FontSize="21" FontWeight="Bold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricBox}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="PACKETS" Style="{StaticResource SmallLabel}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="PacketText" Text="0" Foreground="#F1F7FF" FontSize="21" FontWeight="Bold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricBox}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="LAST UPDATE" Style="{StaticResource SmallLabel}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="LastUpdateText" Text="never" Foreground="#74FF36" FontSize="20" FontWeight="Bold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricBox}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="SENSOR TEMP" Style="{StaticResource SmallLabel}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="TempText" Text="-- °F" Foreground="#F1F7FF" FontSize="21" FontWeight="Bold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricBox}">
                        <StackPanel HorizontalAlignment="Center">
                            <TextBlock Text="CPU USAGE" Style="{StaticResource SmallLabel}" HorizontalAlignment="Center"/>
                            <TextBlock x:Name="CpuText" Text="--" Foreground="#F1F7FF" FontSize="21" FontWeight="Bold" Margin="0,6,0,0"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource MetricBox}">
                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition Width="82"/></Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="RECORDING" Style="{StaticResource SmallLabel}"/>
                                <StackPanel Orientation="Horizontal" Margin="0,6,0,0">
                                    <Ellipse x:Name="RecordDot" Width="10" Height="10" Fill="#FF4238" Margin="0,5,8,0"/>
                                    <TextBlock x:Name="RecordText" Text="Off" Foreground="#9FB1C2" FontWeight="Bold"/>
                                </StackPanel>
                            </StackPanel>
                            <Button x:Name="BtnRecord" Grid.Column="1" Content="Start" Click="BtnRecord_Click" Height="36"/>
                        </Grid>
                    </Border>
                </UniformGrid>

                <Grid x:Name="MainVisualPanel" Grid.Row="1" Margin="0,0,0,8">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2.1*"/>
                        <ColumnDefinition Width="1.6*"/>
                        <ColumnDefinition Width="1.45*"/>
                        <ColumnDefinition Width="1.32*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                        <Grid>
                            <TextBlock Text="ATTITUDE (AHRS)" Style="{StaticResource PanelTitle}"/>
                            <controls:AttitudeIndicator x:Name="AttitudeView" Margin="10,36,10,10"/>
                        </Grid>
                    </Border>

                    <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                        <Grid>
                            <TextBlock Text="3D ORIENTATION" Style="{StaticResource PanelTitle}"/>
                            <controls:Orientation3DControl x:Name="OrientationView" Margin="8,34,8,82"/>
                            <UniformGrid Columns="3" VerticalAlignment="Bottom" Height="76" Margin="6">
                                <Border Style="{StaticResource MetricBox}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="ROLL" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="RollBoxText" Text="0.0°" Style="{StaticResource BigValue}"/></StackPanel></Border>
                                <Border Style="{StaticResource MetricBox}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="PITCH" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="PitchBoxText" Text="0.0°" Style="{StaticResource BigValue}"/></StackPanel></Border>
                                <Border Style="{StaticResource MetricBox}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="YAW" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="YawBoxText" Text="0.0°" Style="{StaticResource BigValue}"/></StackPanel></Border>
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                        <Grid>
                            <TextBlock Text="MAGNETOMETER" Style="{StaticResource PanelTitle}"/>
                            <controls:CompassGauge x:Name="CompassView" Margin="8,34,8,76"/>
                            <UniformGrid Columns="3" VerticalAlignment="Bottom" Height="68" Margin="6">
                                <Border Style="{StaticResource MetricBox}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="X" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="MagXText" Text="--" Foreground="#FF4238" FontSize="20" FontWeight="Bold"/></StackPanel></Border>
                                <Border Style="{StaticResource MetricBox}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="Y" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="MagYText" Text="--" Foreground="#74FF36" FontSize="20" FontWeight="Bold"/></StackPanel></Border>
                                <Border Style="{StaticResource MetricBox}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="Z" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="MagZText" Text="--" Foreground="#3190FF" FontSize="20" FontWeight="Bold"/></StackPanel></Border>
                            </UniformGrid>
                        </Grid>
                    </Border>

                    <Grid Grid.Column="3">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="0.70*"/>
                            <RowDefinition Height="0.55*"/>
                            <RowDefinition Height="0.55*"/>
                            <RowDefinition Height="0.55*"/>
                            <RowDefinition Height="1.75*"/>
                        </Grid.RowDefinitions>

                        <Border Grid.Row="0" Style="{StaticResource PanelBorder}" Padding="8" Margin="0,0,0,5">
                            <StackPanel>
                                <TextBlock Text="SENSOR STATUS" Style="{StaticResource SmallLabel}" Foreground="#F4FAFF"/>
                                <TextBlock x:Name="StatusAccelText" Text="● Accelerometer --" Foreground="#9FB1C2" Margin="0,5,0,0" FontSize="11"/>
                                <TextBlock x:Name="StatusGyroText" Text="● Gyroscope --" Foreground="#9FB1C2" Margin="0,2,0,0" FontSize="11"/>
                                <TextBlock x:Name="StatusMagText" Text="● Magnetometer --" Foreground="#9FB1C2" Margin="0,2,0,0" FontSize="11"/>
                                <TextBlock x:Name="StatusAhrsText" Text="● AHRS --" Foreground="#9FB1C2" Margin="0,2,0,0" FontSize="11"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="1" Style="{StaticResource PanelBorder}" Padding="8" Margin="0,0,0,5">
                            <StackPanel>
                                <TextBlock Text="QUATERNION" Style="{StaticResource SmallLabel}" Foreground="#F4FAFF"/>
                                <TextBlock x:Name="QuatText" Text="W --   X --&#x0a;Y --   Z --" Foreground="#F1F7FF" FontFamily="Consolas" FontSize="12" Margin="0,4,0,0" LineHeight="15"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="2" Style="{StaticResource PanelBorder}" Padding="8" Margin="0,0,0,5">
                            <StackPanel>
                                <TextBlock Text="ACCELERATION (g)" Style="{StaticResource SmallLabel}" Foreground="#F4FAFF"/>
                                <TextBlock x:Name="AccelText" Text="X --   Y --   Z --" Foreground="#F1F7FF" FontFamily="Consolas" FontSize="12" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="3" Style="{StaticResource PanelBorder}" Padding="8" Margin="0,0,0,5">
                            <StackPanel>
                                <TextBlock Text="GYROSCOPE (°/s)" Style="{StaticResource SmallLabel}" Foreground="#F4FAFF"/>
                                <TextBlock x:Name="GyroText" Text="X --   Y --   Z --" Foreground="#F1F7FF" FontFamily="Consolas" FontSize="12" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Border>

                        <Border Grid.Row="4" Style="{StaticResource PanelBorder}" Padding="10" Margin="0">
                            <Grid>
                                <Grid.RowDefinitions><RowDefinition Height="Auto"/><RowDefinition Height="*"/><RowDefinition Height="42"/></Grid.RowDefinitions>
                                <TextBlock Text="FACTORY-TRUST MODE" Style="{StaticResource SmallLabel}" Foreground="#F4FAFF"/>
                                <TextBlock Grid.Row="1" Foreground="#CFE2F3" FontSize="12" TextWrapping="Wrap" LineHeight="18" Margin="0,8,0,6"
                                           Text="REV13 is read-only. It listens to the HWT905 factory-calibrated stream and does not send calibration, baud-change, output-rate, sleep, save, unlock, or register-write commands. Use the reset below only to clear local dashboard view offsets and graphs."/>
                                <Button Grid.Row="2" x:Name="BtnFactoryViewReset2" Content="Factory View Reset" FontSize="12" Padding="2" Margin="2" Foreground="#74FF36" BorderBrush="#55D92B" Click="BtnFactoryViewReset_Click"/>
                            </Grid>
                        </Border>
                    </Grid>
                </Grid>

                <UniformGrid x:Name="SummaryTilesPanel" Grid.Row="2" Columns="6" Margin="0,0,0,8">
                    <Border Style="{StaticResource MetricBox}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="ROLL" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="RollText" Text="0.0°" Style="{StaticResource BigValue}"/></StackPanel></Border>
                    <Border Style="{StaticResource MetricBox}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="PITCH" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="PitchText" Text="0.0°" Style="{StaticResource BigValue}"/></StackPanel></Border>
                    <Border Style="{StaticResource MetricBox}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="YAW" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="YawText" Text="0.0°" Foreground="#FFB323" FontSize="26" FontWeight="Bold"/></StackPanel></Border>
                    <Border Style="{StaticResource MetricBox}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="TEMP" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="TempTileText" Text="-- °F" Foreground="#FFB323" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
                    <Border Style="{StaticResource MetricBox}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="MAG STRENGTH" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="MagStrengthText" Text="--" Foreground="#3190FF" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
                    <Border Style="{StaticResource MetricBox}"><StackPanel HorizontalAlignment="Center"><TextBlock Text="DATA RATE" Style="{StaticResource SmallLabel}"/><TextBlock x:Name="DataRateTileText" Text="0 Hz" Foreground="#3190FF" FontSize="24" FontWeight="Bold"/></StackPanel></Border>
                </UniformGrid>

                <UniformGrid x:Name="GraphsPanel" Grid.Row="3" Columns="3" Margin="0,0,0,8">
                    <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                        <controls:LineGraphControl x:Name="AccelGraph" Title="ACCELERATION (g)" RangeMin="-2" RangeMax="2" Margin="8"/>
                    </Border>
                    <Border Style="{StaticResource PanelBorder}" Margin="0,0,8,0">
                        <controls:LineGraphControl x:Name="GyroGraph" Title="GYROSCOPE (°/s)" RangeMin="-250" RangeMax="250" Margin="8"/>
                    </Border>
                    <Border Style="{StaticResource PanelBorder}" Margin="0">
                        <controls:LineGraphControl x:Name="AngleGraph" Title="ROLL / PITCH / YAW (°)" RangeMin="-180" RangeMax="180" Margin="8"/>
                    </Border>
                </UniformGrid>

                <Grid x:Name="BottomDataPanel" Grid.Row="4">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1.45*"/>
                        <ColumnDefinition Width="1.45*"/>
                        <ColumnDefinition Width="1.42*"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Style="{StaticResource PanelBorder}" Padding="14" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="26"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <TextBlock Text="DATA LOG" FontWeight="Bold" Foreground="#F4FAFF"/>
                            <TextBox x:Name="LogBox" Grid.Row="1" IsReadOnly="True" TextWrapping="NoWrap" FontFamily="Consolas" FontSize="13" VerticalScrollBarVisibility="Auto" BorderThickness="0" Background="#060D14"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="1" Style="{StaticResource PanelBorder}" Padding="14" Margin="0,0,8,0">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="26"/><RowDefinition Height="*"/></Grid.RowDefinitions>
                            <TextBlock Text="SERIAL HEALTH (READ-ONLY)" FontWeight="Bold" Foreground="#F4FAFF"/>
                            <TextBox x:Name="RawBox" Grid.Row="1" IsReadOnly="True" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" BorderThickness="0" Background="#060D14" Foreground="#9EEBFF"/>
                        </Grid>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource PanelBorder}" Padding="14">
                        <Grid>
                            <Grid.RowDefinitions><RowDefinition Height="26"/><RowDefinition Height="*"/><RowDefinition Height="48"/></Grid.RowDefinitions>
                            <TextBlock Text="SAVE DATA" FontWeight="Bold" Foreground="#F4FAFF"/>
                            <Grid Grid.Row="1" Margin="0,4,0,0">
                                <Grid.RowDefinitions><RowDefinition/><RowDefinition/></Grid.RowDefinitions>
                                <Grid.ColumnDefinitions><ColumnDefinition Width="50"/><ColumnDefinition Width="*"/><ColumnDefinition Width="94"/></Grid.ColumnDefinitions>
                                <TextBlock Text="File:" Style="{StaticResource SmallLabel}" VerticalAlignment="Center"/>
                                <TextBox x:Name="SaveFileText" Grid.Column="1" IsReadOnly="True" Text="not recording"/>
                                <TextBlock Grid.Row="1" Text="Path:" Style="{StaticResource SmallLabel}" VerticalAlignment="Center"/>
                                <TextBox x:Name="SavePathText" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Text="Documents\HWT905Dashboard"/>
                                <Button Grid.Column="2" Grid.RowSpan="2" Content="Change..." Click="BtnChangeFolder_Click"/>
                            </Grid>
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                                <Button Content="Open Folder" Click="BtnOpenFolder_Click"/>
                                <Button Grid.Column="1" Content="Clear Log" BorderBrush="#FF4238" Click="BtnClearLog_Click"/>
                            </Grid>
                        </Grid>
                    </Border>
                </Grid>

                <Border x:Name="ModeInfoPanel" Grid.Row="1" Grid.RowSpan="4" Style="{StaticResource PanelBorder}" Padding="26" Visibility="Collapsed">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <TextBlock x:Name="ModeInfoTitle" Text="ABOUT" Foreground="#F4FAFF" FontSize="28" FontWeight="Bold" Margin="0,0,0,14"/>
                        <TextBlock x:Name="ModeInfoText" Grid.Row="1" Foreground="#CFE2F3" FontSize="17" TextWrapping="Wrap" LineHeight="27"
                                   Text="HWT905 Dashboard REV13&#x0a;&#x0a;REV13 is factory-trust/read-only. It removes HWT905 hardware write controls and trusts the factory-calibrated stream.&#x0a;&#x0a;Overview shows everything. Attitude focuses AHRS/3D/compass. Sensors focuses live packet values. Graphs gives more graph room. About explains the read-only safety model.&#x0a;&#x0a;Factory View Reset is local only. It clears dashboard offsets/graphs and never writes to the sensor."/>
                    </Grid>
                </Border>

            </Grid>
        </Grid>

        <Border Grid.Row="2" Background="#05080C" BorderBrush="#142230" BorderThickness="0,1,0,0">
            <Grid>
                <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                <TextBlock Text="  HWT905 Dashboard REV13  •  Factory-trust/read-only" Foreground="#9FB1C2" VerticalAlignment="Center"/>
                <TextBlock x:Name="FooterText" Grid.Column="1" Text="Ready" Foreground="#D6E6F5" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                <StackPanel Grid.Column="2" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,12,0">
                    <TextBlock Text="Built for WitMotion HWT905-TTL" Foreground="#9FB1C2" Margin="0,0,10,0"/>
                    <Ellipse Width="12" Height="12" Fill="#74FF36"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
