<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net8.0-windows</TargetFramework>
    <UseWPF>true</UseWPF>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>disable</ImplicitUsings>
    <Nullable>disable</Nullable>
    <AssemblyName>HWT905Dashboard</AssemblyName>
    <RootNamespace>HWT905Dashboard</RootNamespace>
    <Platforms>AnyCPU;x64</Platforms>
    <Version>13.0.0</Version>
    <AssemblyVersion>13.0.0.0</AssemblyVersion>
    <FileVersion>13.0.0.0</FileVersion>
    <InformationalVersion>REV13-factory-trust-readonly</InformationalVersion>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="System.IO.Ports" Version="8.0.0" />
  </ItemGroup>
</Project>
